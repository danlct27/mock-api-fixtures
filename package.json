{
  "name": "mock-api-fixtures",
  "version": "0.1.0",
  "description": "Capture real API responses as test fixtures with auto-generated types",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mock-api-fixtures": "src/cli/index.js"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": ["test-fixtures", "mock-data", "api-testing", "typescript", "msw"],
  "engines": {
    "node": ">=24.0.0"
  },
  "author": "Dan Li",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danlct27/mock-api-fixtures"
  },
  "bugs": {
    "url": "https://github.com/danlct27/mock-api-fixtures/issues"
  },
  "homepage": "https://github.com/danlct27/mock-api-fixtures#readme",
  "dependencies": {
    "commander": "^12.0.0",
    "prettier": "^3.2.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-jsdoc": "^62.8.0"
  }
}