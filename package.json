    "node": ">=24.0.0"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "prettier": "^3.2.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0"
  }
}